<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:QuitSmoke.ViewModels"
             Title="📊 Historial"
             x:DataType="vm:HistoryPageViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            
            <!-- Estadísticas principales -->
            <Frame Padding="20" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="16">
                    <Label Text="📈 Estadísticas Generales" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />
                    
                    <!-- Grid de estadísticas -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                        
                        <!-- Total cigarros -->
                        <Border Grid.Row="0" Grid.Column="0" 
                                BackgroundColor="#E8F4FD" 
                                Stroke="#3498DB" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🚬" FontSize="24" HorizontalOptions="Center" />
                                <Label Text="{Binding TotalCigarettes}" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#2980B9" 
                                       HorizontalOptions="Center" />
                                <Label Text="Total cigarros" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Días registrados -->
                        <Border Grid.Row="0" Grid.Column="1" 
                                BackgroundColor="#E8F5E8" 
                                Stroke="#27AE60" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📅" FontSize="24" HorizontalOptions="Center" />
                                <Label Text="{Binding TotalDays}" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#27AE60" 
                                       HorizontalOptions="Center" />
                                <Label Text="Días registrados" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Promedio por día -->
                        <Border Grid.Row="1" Grid.Column="0" 
                                BackgroundColor="#FDF2E9" 
                                Stroke="#E67E22" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                <Label Text="{Binding AveragePerDay, StringFormat='{0:F1}'}" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#D68910" 
                                       HorizontalOptions="Center" />
                                <Label Text="Promedio/día" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Reducción lograda -->
                        <Border Grid.Row="1" Grid.Column="1" 
                                BackgroundColor="#E8F5E8" 
                                Stroke="#27AE60" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📉" FontSize="24" HorizontalOptions="Center" />
                                <Label Text="{Binding TotalProgress, StringFormat='{0:P0}'}" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#27AE60" 
                                       HorizontalOptions="Center" />
                                <Label Text="Reducción lograda" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Resumen textual -->
                        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                                BackgroundColor="#F8F9FA" 
                                Stroke="#6C757D" 
                                StrokeThickness="1" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="12">
                            <Label Text="{Binding TotalSummaryText}" 
                                   FontSize="14" 
                                   TextColor="#495057" 
                                   HorizontalOptions="Center" 
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Estadísticas de tiempo entre cigarros -->
            <Frame Padding="20" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="16">
                    <Label Text="⏱️ Tiempo entre cigarros" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />
                    
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <!-- Mínimo -->
                        <Border Grid.Column="0" 
                                BackgroundColor="#D5DBDB" 
                                Stroke="#85929E" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="⚡" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding MinTimeBetween}" 
                                       FontSize="14" 
                                       FontAttributes="Bold" 
                                       TextColor="#5D6D7E" 
                                       HorizontalOptions="Center" 
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Mínimo" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Promedio -->
                        <Border Grid.Column="1" 
                                BackgroundColor="#FEF9E7" 
                                Stroke="#F4D03F" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📈" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding AverageTimeBetween}" 
                                       FontSize="14" 
                                       FontAttributes="Bold" 
                                       TextColor="#B7950B" 
                                       HorizontalOptions="Center" 
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Promedio" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Máximo -->
                        <Border Grid.Column="2" 
                                BackgroundColor="#E8F8F5" 
                                Stroke="#58D68D" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🏆" FontSize="20" HorizontalOptions="Center" />
                                <Label Text="{Binding MaxTimeBetween}" 
                                       FontSize="14" 
                                       FontAttributes="Bold" 
                                       TextColor="#239B56" 
                                       HorizontalOptions="Center" 
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Máximo" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Gráfica por día -->
            <Frame Padding="16" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="📈 Gráfica por día (últimos 30 días)" 
                           FontSize="16" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />
                    <GraphicsView HeightRequest="200" Drawable="{Binding ChartDrawable}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Tabla de registros -->
            <Frame Padding="0" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout>
                    <!-- Header -->
                    <Border BackgroundColor="#34495E" 
                            StrokeShape="RoundRectangle 15,15,0,0" 
                            Padding="16">
                        <Grid ColumnDefinitions="2*,*">
                            <Label Text="📋 Todos los registros" 
                                   FontSize="16" 
                                   FontAttributes="Bold" 
                                   TextColor="White" />
                            <Label Grid.Column="1" 
                                   Text="Tiempo hasta siguiente" 
                                   FontSize="14" 
                                   FontAttributes="Bold" 
                                   HorizontalTextAlignment="End" 
                                   TextColor="White" />
                        </Grid>
                    </Border>
                    
                    <!-- Lista de registros -->
                    <CollectionView ItemsSource="{Binding HistoryRows}" 
                                    SelectionMode="None"
                                    BackgroundColor="Transparent">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryRow">
                                <Border BackgroundColor="White" 
                                        Stroke="#E5E5E5" 
                                        StrokeThickness="0.5">
                                    <Grid Padding="16,12" 
                                          ColumnDefinitions="2*,*" 
                                          ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding DateTimeText}" 
                                                   FontSize="14" 
                                                   FontAttributes="Bold" 
                                                   TextColor="#2C3E50" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" 
                                               Text="{Binding DeltaText}" 
                                               FontSize="14" 
                                               HorizontalTextAlignment="End" 
                                               VerticalOptions="Center"
                                               TextColor="#7F8C8D" 
                                               FontAttributes="Bold" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón actualizar -->
            <Button Text="🔄 Actualizar datos" 
                    Command="{Binding RefreshCommand}" 
                    BackgroundColor="#3498DB" 
                    TextColor="White" 
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50" />
                    
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
