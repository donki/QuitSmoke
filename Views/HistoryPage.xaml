<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="📊 Historial">

    <Grid>
        <!-- Spinner de carga -->
        <VerticalStackLayout x:Name="LoadingView"
                             IsVisible="True"
                             HorizontalOptions="Center" 
                             VerticalOptions="Center"
                             Spacing="16">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True" 
                               Color="#3498DB" 
                               HeightRequest="50" 
                               WidthRequest="50" />
            <Label Text="Cargando historial..." 
                   FontSize="16" 
                   TextColor="#7F8C8D" 
                   HorizontalOptions="Center" />
        </VerticalStackLayout>
        
        <!-- Contenido principal -->
        <ScrollView x:Name="ContentView" IsVisible="False">
            <VerticalStackLayout Padding="16" Spacing="16">
            
            <!-- Estadísticas principales -->
            <Frame Padding="20" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="16">
                    <Label Text="📈 Estadísticas Generales" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />
                    
                    <!-- Grid de estadísticas -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                        
                        <!-- Total cigarros -->
                        <Border Grid.Row="0" Grid.Column="0" 
                                BackgroundColor="#E8F4FD" 
                                Stroke="#3498DB" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🚬" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalCigarettesLabel"
                                       Text="0"
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#2980B9" 
                                       HorizontalOptions="Center" />
                                <Label Text="Total cigarros" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Días registrados -->
                        <Border Grid.Row="0" Grid.Column="1" 
                                BackgroundColor="#E8F5E8" 
                                Stroke="#27AE60" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📅" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalDaysLabel"
                                       Text="0"
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#27AE60" 
                                       HorizontalOptions="Center" />
                                <Label Text="Días registrados" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Promedio por día -->
                        <Border Grid.Row="1" Grid.Column="0" 
                                BackgroundColor="#FDF2E9" 
                                Stroke="#E67E22" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="AveragePerDayLabel"
                                       Text="0.0"
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#D68910" 
                                       HorizontalOptions="Center" />
                                <Label Text="Promedio/día" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Reducción lograda -->
                        <Border Grid.Row="1" Grid.Column="1" 
                                BackgroundColor="#E8F5E8" 
                                Stroke="#27AE60" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📉" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="ReductionLabel"
                                       Text="0%"
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#27AE60" 
                                       HorizontalOptions="Center" />
                                <Label Text="Reducción lograda" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Resumen textual -->
                        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                                BackgroundColor="#F8F9FA" 
                                Stroke="#6C757D" 
                                StrokeThickness="1" 
                                StrokeShape="RoundRectangle 8" 
                                Padding="12">
                            <Label x:Name="SummaryLabel"
                                   Text="Cargando estadísticas..."
                                   FontSize="14" 
                                   TextColor="#495057" 
                                   HorizontalOptions="Center" 
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Estadísticas económicas -->
            <Frame Padding="20" CornerRadius="15" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="16">
                    <Label Text="💰 Estadísticas Económicas" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center" />
                    
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <!-- Total gastado -->
                        <Border Grid.Row="0" Grid.Column="0" 
                                BackgroundColor="#FADBD8" 
                                Stroke="#E74C3C" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="💸" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalSpentLabel"
                                       Text="€0.00"
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#C0392B" 
                                       HorizontalOptions="Center" />
                                <Label Text="Total gastado" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Total ahorrado -->
                        <Border Grid.Row="0" Grid.Column="1" 
                                BackgroundColor="#D5F4E6" 
                                Stroke="#27AE60" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="💚" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalSavedLabel"
                                       Text="€0.00"
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#27AE60" 
                                       HorizontalOptions="Center" />
                                <Label Text="Total ahorrado" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Gasto promedio por día -->
                        <Border Grid.Row="1" Grid.Column="0" 
                                BackgroundColor="#FEF9E7" 
                                Stroke="#F39C12" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="AverageSpentLabel"
                                       Text="€0.00"
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#D68910" 
                                       HorizontalOptions="Center" />
                                <Label Text="Promedio/día" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        
                        <!-- Porcentaje de ahorro -->
                        <Border Grid.Row="1" Grid.Column="1" 
                                BackgroundColor="#EBF5FB" 
                                Stroke="#3498DB" 
                                StrokeThickness="2" 
                                StrokeShape="RoundRectangle 10" 
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📈" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="SavingsPercentageLabel"
                                       Text="0.0%"
                                       FontSize="16" 
                                       FontAttributes="Bold" 
                                       TextColor="#2980B9" 
                                       HorizontalOptions="Center" />
                                <Label Text="% de ahorro" 
                                       FontSize="12" 
                                       TextColor="#34495E" 
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón actualizar -->
            <Button Text="🔄 Actualizar datos" 
                    Clicked="OnRefreshClicked"
                    BackgroundColor="#3498DB" 
                    TextColor="White" 
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50" />
                    
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>