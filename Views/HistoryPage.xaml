<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.HistoryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Historial">

    <Grid>
        <!-- Spinner de carga -->
        <VerticalStackLayout x:Name="LoadingView"
                             IsVisible="True"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="16">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               HeightRequest="50"
                               WidthRequest="50" />
            <Label x:Name="LoadingLabel"
                   Text="Cargando historial..."
                   Style="{StaticResource HintText}"
                   FontSize="16"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Contenido principal -->
        <ScrollView x:Name="ContentView" IsVisible="False">
            <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Estadísticas principales -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label x:Name="GeneralStatsLabel"
                           Text="Estadísticas Generales"
                           Style="{StaticResource CardTitle}"
                           HorizontalOptions="Center" />

                    <!-- Grid de estadísticas -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">

                        <!-- Total cigarros -->
                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Primary}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="🚬" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalCigarettesLabel"
                                       Text="0"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="TotalCigarettesCaption"
                                       Text="Total cigarros"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Días registrados -->
                        <Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Success}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📅" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalDaysLabel"
                                       Text="0"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Success}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="DaysRecordedCaption"
                                       Text="Días registrados"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Promedio por día -->
                        <Border Grid.Row="1" Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Accent}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="AveragePerDayLabel"
                                       Text="0.0"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Accent}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="AvgPerDayCaption"
                                       Text="Promedio/día"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Reducción lograda -->
                        <Border Grid.Row="1" Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Success}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📉" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="ReductionLabel"
                                       Text="0%"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Success}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="ReductionCaption"
                                       Text="Reducción lograda"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Resumen textual -->
                        <Border Grid.Row="2" Grid.ColumnSpan="2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource SeparatorLight}, Dark={StaticResource SeparatorDark}}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="12">
                            <Label x:Name="SummaryLabel"
                                   Text="Cargando estadísticas..."
                                   Style="{StaticResource BodyText}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Estadísticas económicas -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label x:Name="EconomicStatsLabel"
                           Text="Estadísticas Económicas"
                           Style="{StaticResource CardTitle}"
                           HorizontalOptions="Center" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <!-- Total gastado -->
                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Danger}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="💸" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalSpentLabel"
                                       Text="€0.00"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Danger}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="TotalSpentCaption"
                                       Text="Total gastado"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total ahorrado -->
                        <Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Success}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="💚" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="TotalSavedLabel"
                                       Text="€0.00"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Success}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="TotalSavedCaption"
                                       Text="Total ahorrado"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Gasto promedio por día -->
                        <Border Grid.Row="1" Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Accent}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="AverageSpentLabel"
                                       Text="€0.00"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Accent}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="AvgSpentCaption"
                                       Text="Promedio/día"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Porcentaje de ahorro -->
                        <Border Grid.Row="1" Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                Stroke="{StaticResource Primary}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10"
                                Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="📈" FontSize="24" HorizontalOptions="Center" />
                                <Label x:Name="SavingsPercentageLabel"
                                       Text="0.0%"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                                <Label x:Name="SavingsPctCaption"
                                       Text="% de ahorro"
                                       Style="{StaticResource HintText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Botón actualizar -->
            <Button x:Name="RefreshButton"
                    Text="Actualizar datos"
                    Clicked="OnRefreshClicked"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="50" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
