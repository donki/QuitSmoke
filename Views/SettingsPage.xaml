<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:QuitSmoke.Models"
             Title="Configuración">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="24">

            <!-- Header -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Configuración"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />
                <Label Text="Preferencias y permisos"
                       Style="{StaticResource HintText}"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Tarjetas estado rápido -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🔋" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Ahorro batería" Style="{StaticResource BodyText}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label x:Name="BatteryOptStatus" Text="Sin verificar" Style="{StaticResource HintText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🚀" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Autostart" Style="{StaticResource BodyText}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label x:Name="AutostartStatus" Text="Manual" Style="{StaticResource HintText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Configuración de Permisos -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Configuración de Permisos"
                       Style="{StaticResource CardTitle}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0" />

                <Button Text="🔍 Verificar Estado de Permisos"
                        Clicked="OnCheckPermissionsClicked"
                        Style="{StaticResource OutlineButton}"
                        HeightRequest="44" />

                <Button Text="⚙️ Configurar Todos los Permisos"
                        Clicked="OnConfigureAllPermissionsClicked"
                        Style="{StaticResource PrimaryButton}"
                        HeightRequest="44" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="🔋 Batería"
                            Clicked="OnBatteryOptimizationClicked"
                            Style="{StaticResource AccentButton}"
                            FontSize="12"
                            HeightRequest="40" />

                    <Button Grid.Column="1"
                            Text="🚀 Autostart"
                            Clicked="OnAutostartClicked"
                            Style="{StaticResource OutlineButton}"
                            FontSize="12"
                            HeightRequest="40" />
                </Grid>

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource DangerSurfaceLight}, Dark={StaticResource DangerSurfaceDark}}"
                        Stroke="{StaticResource Accent}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="12">
                    <Label Text="💡 Para un funcionamiento óptimo, configure todos los permisos para ejecución en segundo plano."
                           Style="{StaticResource BodyText}"
                           FontSize="12"
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>

            <!-- Ajustes propios -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Cigarros máximos por día" Style="{StaticResource CardTitle}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="−" FontSize="20" BackgroundColor="{StaticResource Danger}" TextColor="{StaticResource White}" WidthRequest="50" HeightRequest="50" CornerRadius="25" Clicked="OnDecreaseMaxCigarettes" />
                        <Entry x:Name="MaxCigarettesEntry" Grid.Column="1" Text="20" FontSize="18" HorizontalTextAlignment="Center" Keyboard="Numeric" />
                        <Button Grid.Column="2" Text="+" FontSize="20" BackgroundColor="{StaticResource Success}" TextColor="{StaticResource White}" WidthRequest="50" HeightRequest="50" CornerRadius="25" Clicked="OnIncreaseMaxCigarettes" />
                    </Grid>
                    <Label x:Name="TimeBetweenLabel" Text="Tiempo entre cigarros: --" Style="{StaticResource HintText}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Horario -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Horario de vigilia" Style="{StaticResource CardTitle}" />
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Hora de despertar:" Style="{StaticResource BodyText}" FontSize="16" VerticalOptions="Center" />
                        <TimePicker x:Name="WakeUpTimePicker" Grid.Row="0" Grid.Column="1" Time="07:00:00" FontSize="16" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Hora de dormir:" Style="{StaticResource BodyText}" FontSize="16" VerticalOptions="Center" />
                        <TimePicker x:Name="SleepTimePicker" Grid.Row="1" Grid.Column="1" Time="23:00:00" FontSize="16" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Configuración de Precios -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Configuración de Precios" Style="{StaticResource CardTitle}" />

                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Precio de cajetilla:" Style="{StaticResource BodyText}" FontSize="16" VerticalOptions="Center" />
                        <Entry x:Name="PackPriceEntry" Grid.Row="0" Grid.Column="1" Text="5.00" FontSize="16" Keyboard="Numeric" Placeholder="5.00" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Cigarros por cajetilla:" Style="{StaticResource BodyText}" FontSize="16" VerticalOptions="Center" />
                        <Entry x:Name="CigarettesPerPackEntry" Grid.Row="1" Grid.Column="1" Text="20" FontSize="16" Keyboard="Numeric" Placeholder="20" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Divisa:" Style="{StaticResource BodyText}" FontSize="16" VerticalOptions="Center" />
                        <Picker x:Name="CurrencyPicker" Grid.Row="2" Grid.Column="1" FontSize="16" />
                    </Grid>

                    <Label x:Name="PricePerCigaretteLabel" Text="Precio por cigarrillo: €0.25" Style="{StaticResource HintText}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Acciones -->
            <VerticalStackLayout Spacing="10">
                <Button Text="💾 Guardar Configuración" Style="{StaticResource PrimaryButton}" HeightRequest="50" CornerRadius="25" Clicked="OnSaveSettingsClicked" />
                <Button Text="📉 Reducir Máximo (Progreso gradual)" Style="{StaticResource AccentButton}" FontSize="16" HeightRequest="50" CornerRadius="25" Clicked="OnReduceMaxClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
