<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:QuitSmoke.ViewModels"
             xmlns:models="clr-namespace:QuitSmoke.Models"
             Title="QuitSmoke"
             x:DataType="vm:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,10" VerticalOptions="Start">

            <!-- Header -->
            <Label x:Name="WelcomeLabel"
                   Text="QuitSmoke"
                   FontSize="24"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />

            <!-- Consejo aleatorio más visual -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   CornerRadius="15"
                   HasShadow="True"
                   BorderColor="#FFC107">
                <VerticalStackLayout Spacing="12">
                    <!-- Icono grande del consejo -->
                    <Label Text="{Binding RandomTipIcon}"
                           FontSize="48"
                           HorizontalOptions="Center" />

                    <!-- Titulo del consejo -->
                    <Label Text="{Binding RandomTipTitle}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="Black" />

                    <!-- Mensaje del consejo -->
                    <Label Text="{Binding RandomTipText}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           TextColor="DarkGray" />

                    <!-- Etiqueta de consejo -->
                    <Border BackgroundColor="#FFF3CD"
                            Stroke="#FFC107"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 15"
                            Padding="8,4"
                            HorizontalOptions="Center">
                        <Label Text="✨ Tip Smart"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#856404" />
                    </Border>
                </VerticalStackLayout>
            </Frame>

            <!-- Progress Display -->
            <Frame BackgroundColor="{StaticResource Secondary}" 
                   Padding="20" 
                   CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding ProgressText}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"
                           TextColor="Black" />

                    <ProgressBar Progress="{Binding ProgressPercentage}"
                                 ProgressColor="{StaticResource Primary}"
                                 BackgroundColor="LightGray"
                                 HeightRequest="10" />

                    <Label Text="{Binding SmokingData.RemainingCigarettes, StringFormat='Cigarros restantes: {0}'}"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="Black" />
                </VerticalStackLayout>
            </Frame>

            <!-- Información de tiempos -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Último cigarro -->
                <Frame Grid.Column="0"
                       BackgroundColor="LightCoral" 
                       Padding="12" 
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="🕐"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding LastCigaretteTimeText}"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="DarkRed" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Próximo cigarro -->
                <Frame Grid.Column="1"
                       BackgroundColor="LightBlue" 
                       Padding="12" 
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="⏰"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding NextRecommendedTimeText}"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="DarkBlue" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Acciones rápidas en línea -->
            <Grid ColumnDefinitions="*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="💪 Esperaré"
                        FontSize="14"
                        BackgroundColor="Green"
                        TextColor="White"
                        Command="{Binding DelaySmokingCommand}" />
            </Grid>

            <!-- Tiempo sin fumar y beneficios -->
            <Frame BackgroundColor="White" Padding="16" CornerRadius="15" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <!-- Tiempo sin fumar destacado -->
                    <Border BackgroundColor="#E8F5E8"
                            Stroke="#28A745"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 10"
                            Padding="12">
                        <Label Text="{Binding TimeSinceLastSmokeText}" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#155724" />
                    </Border>

                    <!-- Titulo de beneficios -->
                    <Label Text="🏆 Beneficios de salud alcanzados" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"
                           TextColor="#28A745" />

                    <!-- Lista de beneficios -->
                    <CollectionView ItemsSource="{Binding HealthBenefits}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:BenefitItem">
                                <Border Padding="12,8" StrokeShape="RoundRectangle 8" BackgroundColor="#F8F9FA" Stroke="#DEE2E6" StrokeThickness="1">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Achieved}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#D4EDDA" />
                                            <Setter Property="Stroke" Value="#28A745" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <Label Text="{Binding Icon}" FontSize="20" VerticalOptions="Center" TextColor="#28A745">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Achieved}" Value="False">
                                                    <Setter Property="TextColor" Value="#6C757D" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Grid.Column="1" Text="{Binding Description}" FontSize="14" LineBreakMode="WordWrap" VerticalOptions="Center" TextColor="Black" FontAttributes="Bold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Achieved}" Value="False">
                                                    <Setter Property="TextColor" Value="#6C757D" />
                                                    <Setter Property="FontAttributes" Value="None" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Smoke Button principal -->
            <Button x:Name="SmokeBtn"
                    Text="🚬 Fumar Cigarro"
                    FontSize="18"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="30"
                    Command="{Binding SmokeCommand}"
                    IsEnabled="{Binding CanSmoke}" />

            <!-- Quick Actions -->
            <Button Text="🔄 Actualizar consejo y datos"
                    FontSize="14"
                    BackgroundColor="Gray"
                    TextColor="White"
                    Command="{Binding RefreshCommand}"
                    CornerRadius="20" />

            <!-- Daily Stats -->
            <Frame BackgroundColor="LightGreen" 
                   Padding="15" 
                   CornerRadius="10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Estadísticas del día"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="Black" />

                    <Label Text="{Binding SmokingData.TimeBetweenCigarettes, StringFormat='Tiempo entre cigarros: {0:hh\\:mm}'}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="Black" />

                    <Label Text="{Binding SmokingData.AwakeHours, StringFormat='Horas despierto: {0:hh\\:mm}'}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="Black" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>