<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:QuitSmoke.Models"
             Title="QuitSmoke">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,10" VerticalOptions="Start">

            <!-- Header -->
            <Label x:Name="WelcomeLabel"
                   Text="QuitSmoke"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />

            <!-- Consejo aleatorio -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="TipIcon"
                           Text="💡"
                           FontSize="48"
                           HorizontalOptions="Center" />

                    <Label x:Name="TipTitle"
                           Text="Consejo del día"
                           Style="{StaticResource CardTitle}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label x:Name="TipText"
                           Text="Mantén la motivación y sigue adelante"
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <Border BackgroundColor="{StaticResource Accent}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 15"
                            Padding="8,4"
                            HorizontalOptions="Center">
                        <Label x:Name="TipSmartLabel"
                               Text="Tip Smart"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Progress Display -->
            <Border Style="{StaticResource Card}" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="ProgressLabel"
                           Text="Progreso del día"
                           Style="{StaticResource CardTitle}"
                           HorizontalOptions="Center" />

                    <ProgressBar x:Name="DayProgressBar"
                                 Progress="0.5"
                                 ProgressColor="{StaticResource Primary}"
                                 HeightRequest="10" />

                    <Label x:Name="RemainingLabel"
                           Text="Cigarros restantes: --"
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Información de tiempos -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Último cigarro -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="🕐"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label x:Name="LastCigaretteLabel"
                               Text="Último: --"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Danger}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Próximo cigarro -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="⏰"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label x:Name="NextCigaretteLabel"
                               Text="Próximo: --"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Tiempo sin fumar -->
            <Border Style="{StaticResource Card}" Padding="16">
                <Border BackgroundColor="{StaticResource Success}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Padding="12">
                    <Label x:Name="TimeSinceLastLabel"
                           Text="Tiempo sin fumar: --"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource White}" />
                </Border>
            </Border>

            <!-- Smoke Button principal -->
            <Button x:Name="SmokeBtn"
                    Style="{StaticResource PrimaryButton}"
                    ImageSource="ic_cigarette_white.png"
                    ContentLayout="Left,8"
                    FontSize="18"
                    HeightRequest="60"
                    CornerRadius="30"
                    Clicked="OnSmokeClicked" />

            <!-- Quick Actions -->
            <Button x:Name="RefreshBtn"
                    Style="{StaticResource OutlineButton}"
                    ImageSource="ic_refresh.png"
                    ContentLayout="Left,8"
                    Clicked="OnRefreshClicked" />

            <!-- Daily Stats -->
            <Border Style="{StaticResource Card}" Padding="15">
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="DailyStatsLabel"
                           Text="Estadísticas del día"
                           Style="{StaticResource CardTitle}"
                           HorizontalOptions="Center" />

                    <Label x:Name="TimeBetweenLabel"
                           Text="Tiempo entre cigarros: --"
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center" />

                    <Label x:Name="AwakeHoursLabel"
                           Text="Horas despierto: --"
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
