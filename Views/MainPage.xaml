<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="QuitSmoke.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:QuitSmoke.ViewModels"
             Title="QuitSmoke"
             x:DataType="vm:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,10" VerticalOptions="Start">

            <!-- Header -->
            <Label x:Name="WelcomeLabel"
                   Text="QuitSmoke"
                   FontSize="24"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />

            <!-- Consejo aleatorio -->
            <Frame BackgroundColor="LightYellow" 
                   Padding="15" 
                   CornerRadius="10"
                   BorderColor="Orange"
                   HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="{Binding RandomTipIcon}"
                               FontSize="20" />
                        <Label Text="💡 Consejo del día"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="DarkOrange" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding RandomTipText}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           TextColor="DarkSlateGray" />
                </VerticalStackLayout>
            </Frame>

            <!-- Progress Display -->
            <Frame BackgroundColor="{StaticResource Secondary}" 
                   Padding="20" 
                   CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding ProgressText}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />

                    <ProgressBar Progress="{Binding ProgressPercentage}"
                                 ProgressColor="{StaticResource Primary}"
                                 BackgroundColor="LightGray"
                                 HeightRequest="10" />

                    <Label Text="{Binding SmokingData.RemainingCigarettes, StringFormat='Cigarros restantes: {0}'}"
                           FontSize="16"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Información de tiempos -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Último cigarro -->
                <Frame Grid.Column="0"
                       BackgroundColor="LightCoral" 
                       Padding="12" 
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="🕐"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding LastCigaretteTimeText}"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="DarkRed" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Próximo cigarro -->
                <Frame Grid.Column="1"
                       BackgroundColor="LightBlue" 
                       Padding="12" 
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="⏰"
                               FontSize="18"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding NextRecommendedTimeText}"
                               FontSize="12"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold"
                               TextColor="DarkBlue" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Acciones rápidas en línea -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="💪 Esperaré"
                        FontSize="14"
                        BackgroundColor="Green"
                        TextColor="White"
                        Command="{Binding DelaySmokingCommand}" />
                <Button Grid.Column="1"
                        Text="🚬 Fumar ahora"
                        FontSize="14"
                        BackgroundColor="Orange"
                        TextColor="White"
                        Command="{Binding SmokeAnywayCommand}" />
            </Grid>

            <!-- Tiempo sin fumar y beneficios -->
            <Frame BackgroundColor="White" Padding="12" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding TimeSinceLastSmokeText}" FontSize="14" HorizontalOptions="Center" />
                    <Label Text="Beneficios de salud" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                    <Label Text="{Binding HealthBenefitsText}" FontSize="13" LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <!-- Smoke Button principal -->
            <Button x:Name="SmokeBtn"
                    Text="🚬 Fumar Cigarro"
                    FontSize="18"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HeightRequest="60"
                    CornerRadius="30"
                    Command="{Binding SmokeCommand}"
                    IsEnabled="{Binding CanSmoke}" />

            <!-- Quick Actions -->
            <Button Text="🔄 Actualizar consejo y datos"
                    FontSize="14"
                    BackgroundColor="Gray"
                    TextColor="White"
                    Command="{Binding RefreshCommand}"
                    CornerRadius="20" />

            <!-- Daily Stats -->
            <Frame BackgroundColor="LightGreen" 
                   Padding="15" 
                   CornerRadius="10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Estadísticas del día"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding SmokingData.TimeBetweenCigarettes, StringFormat='Tiempo entre cigarros: {0:hh\\:mm}'}"
                           FontSize="14"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding SmokingData.AwakeHours, StringFormat='Horas despierto: {0:hh\\:mm}'}"
                           FontSize="14"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>