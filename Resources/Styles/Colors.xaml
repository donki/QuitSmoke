<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== Sistema de diseno Socratic (tokens semanticos claro/oscuro) ===== -->

    <!-- Marca -->
    <Color x:Key="Primary">#2E7D32</Color>
    <Color x:Key="PrimaryDark">#1B5E20</Color>
    <Color x:Key="PrimaryLight">#66BB6A</Color>
    <Color x:Key="Accent">#E67E22</Color>
    <Color x:Key="Danger">#E74C3C</Color>
    <Color x:Key="Success">#27AE60</Color>

    <!-- Superficies -->
    <Color x:Key="PageBackgroundLight">#F5F7FA</Color>
    <Color x:Key="PageBackgroundDark">#12161B</Color>
    <Color x:Key="CardBackgroundLight">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1C2229</Color>
    <Color x:Key="SeparatorLight">#E4E9EF</Color>
    <Color x:Key="SeparatorDark">#2A323C</Color>
    <Color x:Key="DangerSurfaceLight">#FDF2F2</Color>
    <Color x:Key="DangerSurfaceDark">#3A2224</Color>

    <!-- Texto -->
    <Color x:Key="TextPrimaryLight">#2C3E50</Color>
    <Color x:Key="TextPrimaryDark">#E8ECF1</Color>
    <Color x:Key="TextSecondaryLight">#7F8C8D</Color>
    <Color x:Key="TextSecondaryDark">#93A1B0</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- ===== Compatibilidad (claves usadas por AppShell y estilos heredados) ===== -->
    <Color x:Key="Secondary">#E8F5E9</Color>
    <Color x:Key="Tertiary">#1B5E20</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

</ResourceDictionary>
