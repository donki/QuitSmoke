<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="QuitSmoke.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:QuitSmoke.Views"
    xmlns:pages="clr-namespace:QuitSmoke.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="QuitSmoke"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
    FlyoutWidth="260">

    <!-- Plantilla de los items del menu: texto con color segun tema (antes el texto salia
         claro sobre el fondo blanco fijo del flyout y no se veia en modo oscuro). -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid HeightRequest="52" Padding="20,0">
                <Label Text="{Binding Title}"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>


    <!-- Header del menú con safe area -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#2196F3" HeightRequest="140" Padding="20,40,20,20">
            <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                <Label Text="QuitSmoke" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Start" />
                <Label Text="Don't Give Up" 
                       FontSize="12" 
                       TextColor="White"
                       Opacity="0.9"
                       HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Menú hamburguesa -->
    <FlyoutItem Title="🏠 Principal">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <!-- Histórico -->
    <FlyoutItem Title="📈 Histórico">
        <ShellContent ContentTemplate="{DataTemplate local:HistoryPage}" Route="HistoryPage" />
    </FlyoutItem>

    <FlyoutItem Title="⚙️ Configuración">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
    </FlyoutItem>

    <FlyoutItem Title="ℹ️ Acerca de">
        <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}" Route="AboutPage" />
    </FlyoutItem>

    <!-- Footer del menú -->
    <Shell.FlyoutFooter>
        <Grid BackgroundColor="{StaticResource Gray100}" HeightRequest="60" Padding="20">
            <Label Text="v1.10.0 - sOCratic" 
                   FontSize="10" 
                   TextColor="{StaticResource Gray400}"
                   VerticalOptions="Center"
                   HorizontalOptions="Center" />
        </Grid>
    </Shell.FlyoutFooter>

</Shell>