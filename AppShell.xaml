<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="QuitSmoke.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:QuitSmoke.Views"
    xmlns:pages="clr-namespace:QuitSmoke.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="QuitSmoke"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}"
    FlyoutWidth="260">

    <!-- Plantilla de los items del menu: icono vectorial + texto con color segun tema. -->
    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid HeightRequest="52" Padding="20,0" ColumnDefinitions="24,*" ColumnSpacing="16">
                <Image Grid.Column="0"
                       Source="{Binding FlyoutIcon}"
                       HeightRequest="22"
                       WidthRequest="22"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>


    <!-- Header del menú con safe area (color de marca por token) -->
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource Primary}" HeightRequest="140" Padding="20,40,20,20">
            <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                <Label Text="QuitSmoke"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       HorizontalOptions="Start" />
                <Label x:Name="HeaderSubtitleLabel"
                       Text="Don't Give Up"
                       FontSize="12"
                       TextColor="{StaticResource White}"
                       Opacity="0.9"
                       HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Menú hamburguesa -->
    <FlyoutItem x:Name="HomeItem" FlyoutIcon="ic_home.png">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="HistoryItem" FlyoutIcon="ic_history.png">
        <ShellContent ContentTemplate="{DataTemplate local:HistoryPage}" Route="HistoryPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="SettingsItem" FlyoutIcon="ic_settings.png">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
    </FlyoutItem>

    <FlyoutItem x:Name="AboutItem" FlyoutIcon="ic_info.png">
        <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}" Route="AboutPage" />
    </FlyoutItem>

    <!-- Footer del menú (tokens tema-aware; version leida de AppInfo) -->
    <Shell.FlyoutFooter>
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
              HeightRequest="60" Padding="20">
            <Label x:Name="FooterVersionLabel"
                   Text="sOCratic"
                   FontSize="10"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}"
                   VerticalOptions="Center"
                   HorizontalOptions="Center" />
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
