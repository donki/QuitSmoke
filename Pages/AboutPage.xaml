<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuitSmoke.Pages.AboutPage"
             Title="Acerca de">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <!-- 1. Cabecera -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="30,25" Spacing="12">
                    <Image Source="app_logo.png"
                           HeightRequest="96"
                           WidthRequest="96"
                           HorizontalOptions="Center" />

                    <Label Text="QuitSmoke"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" />

                    <Label x:Name="VersionLabel"
                           Text="Versión 1.10.0"
                           Style="{StaticResource HintText}"
                           FontSize="15"
                           HorizontalOptions="Center" />

                    <Label x:Name="DescriptionLabel"
                           Text=""
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Socratic"
                           Style="{StaticResource HintText}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- 2. Contacto -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="14">
                    <Label x:Name="ContactTitleLabel"
                           Text="Contacto"
                           Style="{StaticResource CardTitle}" />

                    <Button Text="jsoladelarosa@gmail.com"
                            Style="{StaticResource OutlineButton}"
                            Clicked="OnContactEmailClicked"
                            HorizontalOptions="Fill" />

                    <Label x:Name="ContactHintLabel"
                           Text=""
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- 3. Apoyo -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="14">
                    <Label x:Name="SupportTitleLabel"
                           Text="Apoya el Desarrollo"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Accent}" />

                    <Button x:Name="SupportButton"
                            Text="Ko-fi.com - Invítame un café"
                            Style="{StaticResource AccentButton}"
                            Clicked="OnDonationClicked"
                            HorizontalOptions="Fill" />

                    <Label x:Name="SupportHintLabel"
                           Text=""
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- 4. Idioma -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="14">
                    <Label x:Name="LanguageTitleLabel"
                           Text="Idioma"
                           Style="{StaticResource CardTitle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button x:Name="SpanishButton"
                                Grid.Column="0"
                                Text="🇪🇸 Español"
                                Style="{StaticResource OutlineButton}"
                                Clicked="OnSpanishClicked" />

                        <Button x:Name="EnglishButton"
                                Grid.Column="1"
                                Text="🇺🇸 English"
                                Style="{StaticResource OutlineButton}"
                                Clicked="OnEnglishClicked" />
                    </Grid>

                    <Label x:Name="LanguageHintLabel"
                           Text=""
                           Style="{StaticResource HintText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- 5. Privacidad -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="12">
                    <Label x:Name="PrivacyTitleLabel"
                           Text="Privacidad"
                           Style="{StaticResource CardTitle}" />

                    <Label x:Name="PrivacyTextLabel"
                           Text=""
                           Style="{StaticResource BodyText}"
                           LineHeight="1.4" />
                </VerticalStackLayout>
            </Border>

            <!-- 6. Licencia -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="12">
                    <Label x:Name="LicenseTitleLabel"
                           Text="Licencia"
                           Style="{StaticResource CardTitle}" />

                    <Label x:Name="LicenseTextLabel"
                           Text=""
                           Style="{StaticResource BodyText}"
                           LineHeight="1.4" />

                    <Label x:Name="LicenseLineLabel"
                           Text=""
                           Style="{StaticResource HintText}" />
                </VerticalStackLayout>
            </Border>

            <!-- 7. Aviso Legal -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Padding="25,20" Spacing="12">
                    <Label x:Name="LegalTitleLabel"
                           Text="Aviso Legal"
                           Style="{StaticResource CardTitle}"
                           TextColor="{StaticResource Danger}" />

                    <Label x:Name="LegalText1Label"
                           Text=""
                           Style="{StaticResource BodyText}"
                           LineHeight="1.4" />

                    <Label x:Name="LegalText2Label"
                           Text=""
                           Style="{StaticResource BodyText}"
                           LineHeight="1.4" />

                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource DangerSurfaceLight}, Dark={StaticResource DangerSurfaceDark}}"
                            Stroke="{StaticResource Danger}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="14">
                        <Label x:Name="LegalWarningLabel"
                               Text="⚠️ Uso bajo su propio riesgo"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Danger}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
