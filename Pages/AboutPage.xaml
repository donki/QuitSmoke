<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuitSmoke.Pages.AboutPage"
             Title="Acerca de"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <StackLayout Padding="20" Spacing="20">

            <!-- Header Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0">
                <StackLayout Padding="30,25" Spacing="15">
                    <Label
                        Text="🚭"
                        FontSize="60"
                        HorizontalOptions="Center" />

                    <Label
                        Text="QuitSmoke"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#2C3E50"
                        HorizontalOptions="Center" />

                    <Label
                        Text="Versión 1.0.0"
                        FontSize="16"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center" />

                    <Label
                        Text="Tu compañero para reducir el consumo de cigarrillos de forma gradual y efectiva"
                        FontSize="14"
                        TextColor="#95A5A6"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Desarrollado con ❤️ para tu salud"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"
                        Margin="0,10,0,0" />
                </StackLayout>
            </Frame>

            <!-- Contact Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0">
                <StackLayout Padding="25,20" Spacing="15">
                    <Label
                        Text="📧 Contacto"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#3498DB" />

                    <Button
                        Text="soporte@quitsmoke.app"
                        FontSize="14"
                        BackgroundColor="Transparent"
                        TextColor="#3498DB"
                        BorderColor="#3498DB"
                        BorderWidth="1"
                        CornerRadius="8"
                        HeightRequest="45"
                        Clicked="OnContactEmailClicked"
                        HorizontalOptions="Fill">
                        <Button.Shadow>
                            <Shadow Brush="#3498DB" Opacity="0.2" Radius="4" Offset="0,2" />
                        </Button.Shadow>
                    </Button>

                    <Label
                        Text="Toca para enviar un correo con tus comentarios o sugerencias"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center" />
                </StackLayout>
            </Frame>

            <!-- Donation Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0">
                <StackLayout Padding="25,20" Spacing="15">
                    <Label
                        Text="☕ Apoya el Desarrollo"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#E67E22" />

                    <Button
                        Text="Ko-fi.com - Invítame un café"
                        FontSize="14"
                        BackgroundColor="#E67E22"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="45"
                        Clicked="OnDonationClicked"
                        HorizontalOptions="Fill">
                        <Button.Shadow>
                            <Shadow Brush="#E67E22" Opacity="0.3" Radius="8" Offset="0,4" />
                        </Button.Shadow>
                    </Button>

                    <Label
                        Text="Tu apoyo ayuda a mantener y mejorar la aplicación"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center" />
                </StackLayout>
            </Frame>

            <!-- Legal Disclaimer Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0">
                <StackLayout Padding="25,20" Spacing="15">
                    <Label
                        Text="⚖️ Aviso Legal"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#E74C3C" />

                    <Frame BackgroundColor="#FDF2F2" 
                           CornerRadius="8" 
                           Padding="15" 
                           HasShadow="False">
                        <StackLayout Spacing="10">
                            <Label
                                Text="Esta aplicación es una herramienta de apoyo para reducir el consumo de cigarrillos. No sustituye el consejo médico profesional."
                                FontSize="13"
                                LineHeight="1.4"
                                TextColor="#2C3E50" />

                            <Label
                                Text="Para dejar de fumar completamente, se recomienda consultar con profesionales de la salud especializados en cesación tabáquica."
                                FontSize="13"
                                LineHeight="1.4"
                                TextColor="#2C3E50" />

                            <Frame BackgroundColor="#E74C3C" 
                                   CornerRadius="6" 
                                   Padding="12" 
                                   HasShadow="False">
                                <Label
                                    Text="⚠️ Esta app es una herramienta de apoyo, no un tratamiento médico"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    LineHeight="1.4"
                                    TextColor="White"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center" />
                            </Frame>
                        </StackLayout>
                    </Frame>
                </StackLayout>
            </Frame>

            <!-- Language Selection Card -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0">
                <StackLayout Padding="25,20" Spacing="15">
                    <Label
                        Text="🌐 Idioma / Language"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#9B59B6" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="🇪🇸 Español"
                                FontSize="14"
                                BackgroundColor="#9B59B6"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="45"
                                Clicked="OnSpanishClicked" />
                        
                        <Button Grid.Column="1"
                                Text="🇺🇸 English"
                                FontSize="14"
                                BackgroundColor="Transparent"
                                TextColor="#9B59B6"
                                BorderColor="#9B59B6"
                                BorderWidth="1"
                                CornerRadius="8"
                                HeightRequest="45"
                                Clicked="OnEnglishClicked" />
                    </Grid>

                    <Label
                        Text="Selecciona tu idioma preferido"
                        FontSize="12"
                        TextColor="#7F8C8D"
                        HorizontalOptions="Center" />
                </StackLayout>
            </Frame>

            <!-- Back Button -->
            <Button
                Text="← Volver"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#3498DB"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"
                Clicked="OnBackClicked"
                HorizontalOptions="Fill"
                Margin="0,10,0,20">
                <Button.Shadow>
                    <Shadow Brush="#3498DB" Opacity="0.3" Radius="8" Offset="0,4" />
                </Button.Shadow>
            </Button>

        </StackLayout>
    </ScrollView>

</ContentPage>